# ─── Database (Render PostgreSQL) ───────────────────────────────────────────
# Use the pooled connection string for DATABASE_URL in production.
DATABASE_URL="postgresql://user:pass@host:5432/scanme?schema=public"
# Direct (non-pooled) URL for running migrations.
DIRECT_URL="postgresql://user:pass@host:5432/scanme?schema=public"

# ─── Auth.js / NextAuth ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic-link sign in (SMTP). On Render use Resend/Postmark SMTP.
EMAIL_SERVER="smtp://user:pass@smtp.resend.com:587"
EMAIL_FROM="ScanMe <login@scanme.app>"

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Salt for hashing visitor fingerprints (rotate carefully — resets unique counts).
SCAN_HASH_SALT="change-me-too"

# ─── Storage (UploadThing OR S3-compatible) ─────────────────────────────────
UPLOADTHING_TOKEN=""
# or
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="scanme-assets"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# ─── Rate limiting (optional — falls back to Postgres if unset) ─────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
